{
  "name": "moneyman",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=24 <26"
  },
  "scripts": {
    "act": "go run github.com/nektos/act@latest",
    "preinstall": "node scripts/check-node-version.mjs",
    "start": "pnpm --filter @moneyman/scraper start",
    "start:container": "docker compose up --abort-on-container-exit",
    "prepare": "husky",
    "build": "pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "jest",
    "test:config": "tsx apps/config-init/src/verify.ts",
    "test:scraper-access": "node --import tsx --test apps/scraper/src/test-scraper-access.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daniel-hauser/moneyman.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/daniel-hauser/moneyman/issues"
  },
  "homepage": "https://github.com/daniel-hauser/moneyman#readme",
  "devDependencies": {
    "@jest/globals": "catalog:",
    "@types/async": "catalog:",
    "@types/debug": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@types/pg-format": "catalog:",
    "husky": "catalog:",
    "jest": "catalog:",
    "jest-mock-extended": "catalog:",
    "pg-mem": "catalog:",
    "prettier": "catalog:",
    "pretty-quick": "catalog:",
    "ts-jest": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "^24.0.0",
      "google-spreadsheet>google-auth-library": "^10.3.0",
      "jest-mock-extended>typescript": "$typescript"
    },
    "patchedDependencies": {
      "ky@2.0.2": "patches/ky+2.0.2.patch"
    }
  }
}
